# Copy this file to .env and fill in your real values.
# .env is git-ignored and must NEVER be committed.

# --- Polymarket CLOB API ---
# Generate at https://clob.polymarket.com → API Keys
POLY_PRIVATE_KEY=YOUR_WALLET_PRIVATE_KEY_HERE
POLY_SAFE_ADDRESS=YOUR_SAFE_ADDRESS_HERE
POLY_API_KEY=YOUR_API_KEY_HERE
POLY_API_SECRET=YOUR_API_SECRET_HERE
POLY_PASSPHRASE=YOUR_API_PASSPHRASE_HERE
POLY_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137

# --- Telegram alerts (optional) ---
# Create a bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID_HERE

# --- Trading parameters ---
PAPER_MODE=true
PORTFOLIO_SIZE=1000.0
MAX_POSITION_PCT=0.02
DAILY_LOSS_CAP_PCT=0.05
MAX_CONCURRENT_POSITIONS=10
